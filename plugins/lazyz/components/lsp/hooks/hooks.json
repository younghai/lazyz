{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "^(apply_patch|Write|Edit|MultiEdit|multi_edit|write|edit|multiedit)$",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook post-tool-use",
						"timeout": 60,
						"statusMessage": "(LazyZ 0.10.2) Checking LSP Diagnostics"
					}
				]
			}
		],
		"PostCompact": [
			{
				"matcher": "manual|auto",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook post-compact",
						"timeout": 5,
						"statusMessage": "(LazyZ 0.10.2) Resetting LSP Diagnostics Cache"
					}
				]
			}
		]
	}
}
