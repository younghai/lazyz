{
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook user-prompt-submit --with-ultrawork",
						"timeout": 10,
						"statusMessage": "(LazyZ 0.1.1) Checking Ulw-Loop Steering"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "^create_goal$",
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/dist/cli.js\" hook pre-tool-use",
						"timeout": 5,
						"statusMessage": "(LazyZ 0.1.1) Enforcing Unlimited Ulw-Loop Budget"
					}
				]
			}
		]
	}
}
